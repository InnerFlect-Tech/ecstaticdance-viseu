# Coolify v4 — produção Hetzner (Nixpacks + volumes já configurados no painel)
# Código em /app; SQLite e uploads nos volumes em /var/www/edv-server/...
# Não mudar paths se os volumes já estão montados aí.

NIXPACKS_NODE_VERSION=22

EDV_SERVER_ROOT=/var/www/edv-server
EDV_REPLACE_CONFIG_FROM_EXAMPLE=0

EDV_USE_SQLITE_MAIN_DB=true
EDV_LINK_USE_SQLITE=true
EDV_LINK_USE_JSON=false
EDV_MAIN_DB_SQLITE_PATH=/var/www/edv-server/data/events-tickets.sqlite
EDV_LINK_SQLITE_PATH=/var/www/edv-server/data/link-bookings.sqlite
EDV_LINK_JSON_PATH=/var/www/edv-server/data/link-registrations-dev.json

EDV_APP_URL=https://ecstaticdanceviseu.pt
EDV_FROM_EMAIL=bilhetes@ecstaticdanceviseu.pt
EDV_FROM_NAME=Ecstatic Dance Viseu
EDV_ORG_NOTIFY_EMAIL=hello@ecstaticdanceviseu.pt
EDV_ORG_INFO_EMAIL=info@ecstaticdanceviseu.pt

# Substituir pelos valores reais no painel:
EDV_STRIPE_PUBLIC_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
EDV_STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
EDV_STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SIGNING_SECRET_HERE
EDV_RECONCILE_TOKEN=change_me
EDV_INSTALL_TOKEN=change_me
EDV_ADMIN_PASSWORD_HASH=$2y$10$60lzFEnkFH2WkKOsVgrNdO45xMnKEWQaWkGKyYQsbwYkxFNdL1cz2

# PORT — definido pelo Coolify (Ports Exposes = 3000)
