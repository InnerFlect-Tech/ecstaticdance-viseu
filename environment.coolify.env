# Coolify v4 — Nixpacks (produção Hetzner ecstaticdanceviseu.pt)
# Colar no painel Environment Variables do serviço (ou importar).
# Paths usam /app (WORKDIR Nixpacks), NÃO /var/www/edv-server (só Dockerfile).

# --- SQLite em volumes persistentes (ver docs/COOLIFY.md) ---
EDV_DB_DRIVER=sqlite
EDV_USE_SQLITE_MAIN_DB=true
EDV_LINK_USE_SQLITE=true
EDV_LINK_USE_JSON=false

EDV_MAIN_DB_SQLITE_PATH=/app/server/data/events-tickets.sqlite
EDV_LINK_SQLITE_PATH=/app/server/data/link-bookings.sqlite
EDV_LINK_JSON_PATH=/app/server/data/link-registrations-dev.json

# Gera config.php a partir do exemplo em cada arranque (secrets só via env)
EDV_REPLACE_CONFIG_FROM_EXAMPLE=1

# --- URLs & mail ---
EDV_APP_URL=https://ecstaticdanceviseu.pt
EDV_APP_TIMEZONE=UTC
EDV_FROM_EMAIL=bilhetes@ecstaticdanceviseu.pt
EDV_FROM_NAME=Ecstatic Dance Viseu
EDV_ORG_NOTIFY_EMAIL=hello@ecstaticdanceviseu.pt
EDV_ORG_INFO_EMAIL=info@ecstaticdanceviseu.pt

# --- Stripe (substituir pelos valores reais) ---
EDV_STRIPE_PUBLIC_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
EDV_STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
EDV_STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SIGNING_SECRET_HERE

# --- Tokens (substituir em produção) ---
EDV_RECONCILE_TOKEN=change_me
EDV_INSTALL_TOKEN=change_me

# --- Admin: bcrypt "admin123" — gerar novo hash para produção ---
EDV_ADMIN_PASSWORD_HASH=$2y$12$ep6Uq2RlUgQsVZy88gdICu96nDUokHKo9FilFZDEIPiO7M9jA6OpG

# PORT — normalmente definido pelo Coolify; Vite preview escuta aqui
# EDV_PHP_API_PORT=8080

# --- MySQL (futuro): desactivar SQLite e preencher EDV_DB_* ---
# EDV_USE_SQLITE_MAIN_DB=false
# EDV_LINK_USE_SQLITE=false
# EDV_DB_DRIVER=mysql
# EDV_DB_HOST=...
# EDV_DB_NAME=...
# EDV_DB_USER=...
# EDV_DB_PASS=...
