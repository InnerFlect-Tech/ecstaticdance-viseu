# Template: same effective defaults as server/api/config.example.php.
# REPLACE secrets before production: EDV_DB_PASS, Stripe keys, EDV_STRIPE_WEBHOOK_SECRET, tokens, EDV_ADMIN_PASSWORD_HASH.
# EDV_ADMIN_PASSWORD_HASH contains `$` — Coolify / plain env: copy the value as-is. Docker Compose env_file: double each `$` if the hash is mangled.
# Paste into Coolify or copy to a local .env (gitignored). PHP reads getenv from the container process.

# --- Container entrypoint (scripts/docker-entrypoint.sh) ---
EDV_SERVER_ROOT=/var/www/edv-server
EDV_REPLACE_CONFIG_FROM_EXAMPLE=0

# --- MySQL (only used when EDV_USE_SQLITE_MAIN_DB=false and/or link storage uses MySQL) ---
EDV_DB_HOST=localhost
EDV_DB_NAME=your_db
EDV_DB_USER=your_user
EDV_DB_PASS=your_pass

# --- Storage mode (true|false|1|0): SQLite defaults match Docker/Coolify quick start ---
EDV_USE_SQLITE_MAIN_DB=true
EDV_LINK_USE_SQLITE=true
EDV_LINK_USE_JSON=false

# --- Paths (SQLite / dev JSON) — inside the app image + volume mount for /var/www/edv-server/data ---
EDV_MAIN_DB_SQLITE_PATH=/var/www/edv-server/data/events-tickets.sqlite
EDV_LINK_SQLITE_PATH=/var/www/edv-server/data/link-bookings.sqlite
EDV_LINK_JSON_PATH=/var/www/edv-server/data/link-registrations-dev.json

# --- Stripe (placeholders — use real keys from dashboard) ---
EDV_STRIPE_PUBLIC_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
EDV_STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
EDV_STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SIGNING_SECRET_HERE

# --- URLs & mail ---
EDV_APP_URL=https://ecstaticdanceviseu.pt
EDV_FROM_EMAIL=bilhetes@ecstaticdanceviseu.pt
EDV_FROM_NAME=Ecstatic Dance Viseu
EDV_ORG_NOTIFY_EMAIL=hello@ecstaticdanceviseu.pt
EDV_ORG_INFO_EMAIL=info@ecstaticdanceviseu.pt

# --- Tokens (replace in production) ---
EDV_RECONCILE_TOKEN=change_me
EDV_INSTALL_TOKEN=change_me

# --- Admin: bcrypt for password "admin123" (same as config.example.php) — generate a new hash for production ---
EDV_ADMIN_PASSWORD_HASH=$2y$12$ep6Uq2RlUgQsVZy88gdICu96nDUokHKo9FilFZDEIPiO7M9jA6OpG

# --- Local dev / preview only (not used by Coolify Dockerfile image) ---
EDV_PHP_API_PORT=8080
